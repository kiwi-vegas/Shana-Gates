{
  "rewrites": [
    { "source": "/blog/post/:slug", "destination": "/api/blog/post-page?slug=:slug" }
  ],
  "functions": {
    "api/assistant/chat.ts": {
      "maxDuration": 120
    },
    "api/blog/publish.ts": {
      "maxDuration": 120
    },
    "api/blog/publish-weekly.ts": {
      "maxDuration": 120
    },
    "api/blog/run-research.ts": {
      "maxDuration": 120
    },
    "api/blog/suggest-images.ts": {
      "maxDuration": 30
    },
    "api/cron/research.ts": {
      "maxDuration": 120
    },
    "api/cron/weekly.ts": {
      "maxDuration": 120
    },
    "api/cron/events.ts": {
      "maxDuration": 120
    },
    "api/blog/enrich-posts.ts": {
      "maxDuration": 120
    },
    "api/blog/inject-post.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/research",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/events",
      "schedule": "0 14 25 * *"
    }
  ]
}
